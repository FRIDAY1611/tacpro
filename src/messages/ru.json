    "subtitle": "\u8899\u90AA\u8915 \u85AA\u90AA\u5199\u68B0\u5378\u85AA\u8918\u6CC4 \u950C\u90AA\u8909\u890C\u85AA\u68B0\u8909 \u80C1 \u950C\u8909\u82AF\u61C8\u87F9\u80C1\u82AF\u5199\u890B\u890C\u80C1\u68B0 \u890C\u90AA\u6CFB\u890C\u61C8\u8914\u68B0\u890B\u6CFB\u82AF\u6CC4 \u82AF\u5199\u68B0\u5378\u5199\u8918",
    "story": {
      "title": "\u88A9\u8909\u82AF\u890E\u61C8\u8C22\u891C \u88A3\u82AF\u5C51\u950C\u90AA\u85AA\u61C8\u61C8",
      "p1": "WearTac \u9225?\u950C\u8909\u82AF\u890E\u68B0\u890B\u890B\u61C8\u82AF\u85AA\u90AA\u8C22\u891C\u85AA\u8918\u6CC4 \u950C\u8909\u82AF\u61C8\u87F9\u80C1\u82AF\u5199\u61C8\u890C\u68B0\u8C22\u891C \u890C\u90AA\u6CFB\u890C\u61C8\u8914\u68B0\u890B\u6CFB\u82AF\u6CC4 \u82AF\u5199\u68B0\u5378\u5199\u8918, \u890B\u950C\u68B0\u8911\u61C8\u90AA\u8C22\u61C8\u87F9\u61C8\u8909\u890D\u891E\u8916\u61C8\u6CC4\u890B\u891F \u85AA\u90AA \u890C\u90AA\u6CFB\u890C\u61C8\u8914\u68B0\u890B\u6CFB\u61C8\u890F \u5378\u61C8\u8C22\u68B0\u890C\u90AA\u890F, \u87F9\u90AA\u8916\u61C8\u890C\u85AA\u8918\u890F \u8915\u8C22\u68B0\u5C51\u90AA\u890F, \u890C\u90AA\u6CFB\u890C\u61C8\u8914\u68B0\u890B\u6CFB\u61C8\u890F \u950C\u68B0\u8909\u8914\u90AA\u890C\u6CFB\u90AA\u890F, \u659C\u82AF\u68B0\u80C1\u82AF\u6CC4 \u890E\u82AF\u8909\u5C51\u68B0 \u61C8 \u890B\u950C\u90AA\u890B\u90AA\u890C\u68B0\u8C22\u891C\u85AA\u82AF\u6CC4 \u82AF\u5199\u68B0\u5378\u5199\u68B0 \u5199\u8C22\u891F \u80C1\u82AF\u68B0\u85AA\u85AA\u8918\u890F, \u950C\u82AF\u8C22\u61C8\u8911\u68B0\u6CC4\u890B\u6CFB\u61C8\u890F \u61C8 \u890C\u890D\u8909\u61C8\u890B\u890C\u61C8\u8914\u68B0\u890B\u6CFB\u61C8\u890F \u8909\u8918\u85AA\u6CFB\u82AF\u80C1.",
      "p2": "\u88A0\u5C51\u68B0\u891F \u5C51\u85AA\u82AF\u8C10\u82AF\u8C22\u68B0\u890C\u85AA\u61C8\u6CC4 \u82AF\u950C\u8918\u890C \u891D\u6CFB\u890B\u950C\u82AF\u8909\u890C\u90AA \u61C8 \u890B\u82AF\u659C\u890B\u890C\u80C1\u68B0\u85AA\u85AA\u890D\u891E \u950C\u8909\u82AF\u61C8\u87F9\u80C1\u82AF\u5199\u890B\u890C\u80C1\u68B0\u85AA\u85AA\u890D\u891E \u659C\u90AA\u87F9\u890D, \u5C51\u8918 \u950C\u8909\u68B0\u5199\u82AF\u890B\u890C\u90AA\u80C1\u8C22\u891F\u68B0\u5C51 \u890D\u890B\u8C22\u890D\u8C10\u61C8 OEM/ODM \u890B\u82AF \u890B\u890C\u8909\u82AF\u8C10\u61C8\u5C51 \u6CFB\u82AF\u85AA\u890C\u8909\u82AF\u8C22\u68B0\u5C51 \u6CFB\u90AA\u8914\u68B0\u890B\u890C\u80C1\u90AA \u82AF\u890C \u950C\u8909\u82AF\u80C1\u68B0\u8909\u6CFB\u61C8 \u890B\u8918\u8909\u891C\u891F \u5199\u82AF \u5199\u82AF\u890B\u890C\u90AA\u80C1\u6CFB\u61C8 \u8C10\u82AF\u890C\u82AF\u80C1\u82AF\u6CC4 \u950C\u8909\u82AF\u5199\u890D\u6CFB\u8911\u61C8\u61C8."
    },
